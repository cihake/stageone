# ─────────────────────────────────────────────────────────────
# StageOne — Server environment variables
# Copy this file to `.env` and fill in real values.
# Per spec §5.2 (Technical Preferences) and release plan §4.1.
# Never commit `.env` — it's gitignored.
# ─────────────────────────────────────────────────────────────

# Runtime mode: development | staging | production
NODE_ENV=development

# Port the API listens on locally. Render assigns its own PORT in prod.
PORT=4000

# CORS — comma-separated list of allowed origins (no trailing slashes).
# Dev:        http://localhost:5173
# Staging:    https://staging.stageone.app
# Production: https://www.stageone.app
CORS_ORIGIN=http://localhost:5173

# ───── MongoDB (Atlas free M0 in dev; see docs/setup/atlas.md) ─────
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/stageone-dev?retryWrites=true&w=majority

# ───── Auth ─────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ───── Cloudinary (media uploads — set up in Phase 2 of release plan) ─────
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ───── AI (added in Phase 4) ─────
OPENAI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ───── Email (Resend — added in Phase 5) ─────
RESEND_API_KEY=

# ───── Observability (Sentry — added in Phase 5) ─────
SENTRY_DSN=
