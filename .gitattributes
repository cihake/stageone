# Normalize line endings on commit; check out using OS default.
* text=auto eol=lf

# Force LF on shell scripts and Husky hooks.
*.sh           text eol=lf
.husky/*       text eol=lf

# Treat these as binary so Git doesn't try to diff or convert them.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.avif binary
*.mp3  binary
*.wav  binary
*.mp4  binary
*.webm binary
*.pdf  binary
