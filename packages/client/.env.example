# ─────────────────────────────────────────────────────────────
# StageOne — Client environment variables
# Copy to `.env` (or `.env.local`) and fill in real values.
# Vite only exposes vars prefixed with VITE_ to the browser.
# ─────────────────────────────────────────────────────────────

# Base URL of the StageOne API.
# Dev:        leave empty — Vite proxies /api to localhost:4000 (vite.config.ts)
# Staging:    https://staging-api.stageone.app
# Production: https://api.stageone.app
VITE_API_URL=

# Sentry DSN for the browser SDK (added in Phase 5).
VITE_SENTRY_DSN=

# Public site URL — used by share links and OG tags.
VITE_SITE_URL=http://localhost:5173
